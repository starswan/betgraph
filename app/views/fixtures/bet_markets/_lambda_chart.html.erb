<% if bet_markets.map { |bm| bm.betfair_market_type.valuer }.include? name %>
  <%= line_chart(lambda_data(bet_markets, name, limit).map { |bmdata| { name: bmdata[:label], data: bmdata[:prices] }},
                 min: 0,
                 xtitle: 'Time',
                 ytitle: 'Expected Value',
                 # max: 5,
                 colors: chart_colours,
                 height: '900px') %>
<% end %>
